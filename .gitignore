# GitHub Actions self-hosted runner (local binary — not tracked)
actions-runner/
runners/

# Graphify output cache
graphify-out/

# ML training artifacts (large binaries — use releases or cloud storage)
# Keep JSON files (vocab, metrics, matchup_metrics) but ignore .npy/.zip/.pt
# (previously a `/data/ml/policy/` blanket rule sat here and re-ignored this
# whole subtree, silently excluding its JSON vocab/metrics files too, contrary
# to the "keep JSON" intent above — git can't re-include a file once its parent
# dir is ignored. Removed; data/ml/** + the *.json negation below already do
# exactly what's wanted without a policy/-specific carve-out.)
data/ml/**
!data/ml/**/
!data/ml/**/*.json

# Stray JSON snapshots
*.json
!package.json
!package-lock.json
!.planning/HANDOFF.json
!data/ml/**/*.json
!data/replays/**/*.json
!tests/fixtures/*.json

# Zips / archives (large binaries — use releases)
*.zip

# Stray empty venvs / temp dirs
.venv-linux/
.trash/

# Cloud-sync duplicate files (OneDrive/Finder " 2.json" etc.)
*\ [0-9].json
*\ [0-9].csv

# Misc
*.bak
*.tmp
audit-fixes.patch
annotations-extracted.json
github-actions-run.png
full-page-text.txt
repo-info.json
actions-run-snapshot.md
workflows-dir.txt
train-models-workflow.txt
